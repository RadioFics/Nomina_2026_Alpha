# ============================================================================
# CONFIGURACIÓN DE BASE DE DATOS SQL SERVER
# ============================================================================
# IMPORTANTE: Esta configuración funciona desde cualquier máquina si el
# servidor SQL Server es accesible en esa IP
#
# Para cambiar de máquina:
# 1. Obtén la IP del servidor: nslookup CM-ITD-P-05 (en PowerShell)
# 2. Reemplaza la IP en SERVER
# 3. Asegúrate de que el firewall permite conexión al puerto 1433
# ============================================================================

# Servidor SQL Server (BD centralizada en esta máquina)
SERVER=CM-ITD-P-05\SQLEXPRESS
# Nombre de la base de datos
DATABASE=MineDax

# ============================================================================
# AUTENTICACIÓN SQL SERVER
# ============================================================================
# IMPORTANTE: Ejecutar setup-servidor.js para crear el usuario de servicio
# automáticamente. Solo necesitas la contraseña de 'sa' una vez.
#
# Temporalmente, usa 'sa' para el setup inicial:
UID=sa
PWD=LetItHappen35*
#
#
# Después del setup, esto se actualizará automáticamente a:
# UID=app_nomina
# PWD=NominaApp2024#

# Driver ODBC (opcional, para compatibilidad)
DRIVER=ODBC Driver 17 for SQL Server

# ============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================================================

# Puerto donde corre la aplicación
PORT=3000

# Ambiente (development, production)
NODE_ENV=development

# Clave secreta para JWT (cambiar en producción)
JWT_SECRET=clave-super-segura-cambiar-en-produccion-minimo-32-caracteres-aleatorios

# ============================================================================
# CONFIGURACIÓN DE EMAIL (Opcional)
# ============================================================================

MAIL_USER=nomina.collectivemining@gmail.com
MAIL_PASS=tu-contraseña-de-aplicacion
APP_URL=http://192.168.1.11:3000