<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config — Configuración IIS para Node.js en Azure App Service (Windows)
  MineDax / NominaCollectiveMining

  Qué hace:
    - Registra el handler iisnode para que IIS sepa que server.js es Node.js
    - Redirige todas las peticiones HTTP a server.js (Express maneja el routing)
    - Oculta node_modules del acceso directo por HTTP
    - Pasa los errores de Express tal como vienen (sin que IIS los intercepte)
-->
<configuration>
  <system.webServer>

    <!-- Handler: todas las peticiones a server.js las procesa iisnode -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode"/>
    </handlers>

    <!-- Rewrite: redirige todo a server.js salvo que el archivo exista en disco -->
    <rewrite>
      <rules>
        <rule name="NodeApp" patternSyntax="ECMAScript" stopProcessing="true">
          <match url=".*"/>
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true"/>
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true"/>
          </conditions>
          <action type="Rewrite" url="server.js"/>
        </rule>
      </rules>
    </rewrite>

    <!-- Seguridad: impide acceso HTTP directo a node_modules -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules"/>
          <add segment=".git"/>
          <add segment=".env"/>
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- Deja que Express envíe sus propios códigos de error -->
    <httpErrors existingResponse="PassThrough"/>

    <!-- iisnode: logging activo para diagnóstico, errores de dev desactivados en prod -->
    <iisnode
      watchedFiles="web.config;*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      devErrorsEnabled="false"
      nodeProcessCommandLine="node.exe"
    />

  </system.webServer>
</configuration>
