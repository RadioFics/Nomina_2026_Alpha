# ============================================================================
# CONFIGURACIÓN EJEMPLO - BASE DE DATOS SQL SERVER
# ============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a .env
# 2. Reemplaza los valores con tus credenciales reales
# 3. Asegúrate de no compartir el .env con credenciales reales
# ============================================================================

# Servidor SQL Server
# Opción 1: Usar hostname (solo funciona en la red local)
#   SERVER=CM-ITD-P-05\SQLEXPRESS
#
# Opción 2: Usar IP (recomendado para escalabilidad)
#   Para obtener la IP: nslookup CM-ITD-P-05 (en PowerShell)
#   SERVER=192.168.1.100\SQLEXPRESS
#
# Opción 3: Usar dominio (ideal para producción)
#   SERVER=servidor.empresa.com\SQLEXPRESS
#
SERVER=AQUI_TU_SERVIDOR_SQL

# Nombre de la base de datos
DATABASE=MineDax

# Usuario de SQL Server (no usar 'sa' en producción)
UID=TU_USUARIO_SQL

# Contraseña de SQL Server
PWD=TU_CONTRASEÑA_SQL

# Driver ODBC (dejar como está)
DRIVER=ODBC Driver 17 for SQL Server

# ============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================================================

# Puerto de la aplicación
PORT=3000

# Ambiente
NODE_ENV=development

# Clave JWT (cambiar en producción a una cadena aleatoria de 32+ caracteres)
JWT_SECRET=clave-super-segura-cambiar-en-produccion-minimo-32-caracteres-aleatorios

# ============================================================================
# CONFIGURACIÓN DE EMAIL (Opcional)
# ============================================================================

MAIL_USER=tu-email@gmail.com
MAIL_PASS=tu-contraseña-de-aplicacion
APP_URL=http://localhost:3000

# Correo de destino para notificaciones de RRHH (formularios públicos de permiso/vacaciones)
MAIL_RRHH=talento.humano@collectivemining.com
