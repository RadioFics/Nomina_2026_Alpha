{
  "name": "nomina-app-ui",
  "version": "1.0.0",
  "description": "Aplicación de Nómina - Collective Mining",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:forms": "node test-formularios.js",
    "test:forms:db": "node test-formularios.js --solo-db",
    "postinstall": "pip install -r requirements.txt --quiet 2>nul || py -m pip install -r requirements.txt --quiet 2>nul || pip3 install -r requirements.txt --quiet 2>/dev/null || echo \"[postinstall] Python packages skipped - PDF via Python may be unavailable\""
  },
  "keywords": [
    "nomina",
    "collective-mining"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tugberkgunver/mcp-sqlserver": "^1.3.2",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.2.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.15.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "msnodesqlv8": "^5.1.9"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
